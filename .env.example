NODE_ENV=development

# App config
UMI_APP_NAME=AILEARN-PLATFORM
UMI_APP_VERSION=1.0.0
UMI_APP_LOCALE=vi-VN
UMI_APP_FALLBACK_LOCALE=en-US

# API config
