NODE_ENV=development

# App config
UMI_APP_NAME=BASE_ADMIN_DASHBOARD
UMI_APP_VERSION=1.0.0
UMI_APP_LOCALE=en-US
UMI_APP_FALLBACK_LOCALE=zh-CN

# API config
UMI_APP_API_URL=http://localhost:3000
UMI_APP_API_TIMEOUT=30000

# Storage config
UMI_APP_STORAGE_PREFIX=antd_pro_

# Feature flags
UMI_APP_ENABLE_ANALYTICS=false
UMI_APP_ENABLE_DEBUG=false
